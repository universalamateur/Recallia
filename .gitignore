# Dependencies installed by npm/yarn/pnpm. Lockfiles should stay tracked.
node_modules/
!package-lock.json
!npm-shrinkwrap.json
!pnpm-lock.yaml
!yarn.lock
!bun.lock
!bun.lockb

# Next.js and general build output.
.next/
out/
dist/
build/

# TypeScript and framework caches.
*.tsbuildinfo
.turbo/
.cache/
.swc/

# Test output from Vitest/coverage tooling and optional Playwright smoke tests.
coverage/
playwright-report/
test-results/
blob-report/

# Local runtime persistence for the MVP. Keep seed data in source, not here.
data/*.json
data/*.sqlite
data/*.sqlite3
data/*.db
data/*.db-*

# Local machine and agent workflow files. These are useful on one workstation
# but should not become part of the portable demo repository.
.local/
.codex/

# Environment files may contain credentials. Commit only documented examples.
.env
.env.*
!.env.example

# OS/editor noise.
.DS_Store
Thumbs.db

# Package manager and tool logs.
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
